# ClawSquad Environment Variables

# Bridge Server
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=9876

# SiliconFlow API Keys (for Kimi-K2.5, GLM-5, etc.)
SILICONFLOW_KIMI_API_KEY=your-siliconflow-kimi-key-here
SILICONFLOW_GLM_API_KEY=your-siliconflow-glm-key-here

# Optional: Claude API Key (for claude CLI)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: OpenAI API Key (for codex CLI)
OPENAI_API_KEY=your-openai-key-here

# Optional: Google API Key (for gemini CLI)
GOOGLE_API_KEY=your-google-key-here
